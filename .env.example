FLASK_APP=run.py
FLASK_ENV=development
PORT=5000

# Clés secrètes — NE PAS committer les valeurs réelles
SECRET_KEY=replace-me-with-a-long-random-string
JWT_SECRET=replace-me-with-another-long-random-string

# Base de données SQL Server
DATABASE_URL=mssql+pyodbc://USER:PASS@localhost/etrans?driver=ODBC+Driver+17+for+SQL+Server
USERS_DATABASE_URL=mssql+pyodbc://USER:PASS@localhost/etrans?driver=ODBC+Driver+17+for+SQL+Server

# Email SMTP
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-smtp-password
