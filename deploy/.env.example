# Example environment variables for deployment
# Copy to .env and set secure values before deploying

FLASK_ENV=production
SECRET_KEY=change-me
JWT_SECRET=change-me
DATABASE_URL=mssql+pyodbc://sa:YourStrong!Pass@mssql:1433/etrans?driver=ODBC+Driver+17+for+SQL+Server
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-app-password

# MSSQL SA password (used by docker-compose mssql service)
SA_PASSWORD=YourStrong!Pass
